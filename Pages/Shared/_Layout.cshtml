                        <div class="form-group">
                            <label class="form-label">Nom du projet *</label>
                            <input type="text" class="form-input" id="editProjectName" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Code projet</label>
                            <input type="text" class="form-input" id="editProjectCode" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Type de projet *</label>
                            <select class="form-select" id="editProjectType" required>
                                <option value="Route">Routes &amp; Autoroutes</option>
                                <option value="Pont">Ponts &amp; Viaducs</option>
                                <option value="Batiment">Bâtiments Publics</option>
                                <option value="Assainissement">Assainissement</option>
                                <option value="Energie">Énergie &amp; Réseaux</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Priorité</label>
                            <select class="form-select" id="editProjectPriority">
                                <option value="Basse">Basse</option>
                                <option value="Moyenne">Moyenne</option>
                                <option value="Haute">Haute</option>
                                <option value="Urgente">Urgente</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Statut</label>
                            <select class="form-select" id="editProjectStatus">
                                <option value="EnPlanification">En planification</option>
                                <option value="EnCours">En cours</option>
                                <option value="EnPause">En pause</option>
                                <option value="EnRetard">En retard</option>
                                <option value="Termine">Terminé</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Montant du projet (DA) *</label>
                            <input type="number" class="form-input" id="editProjectBudget" required />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Caution (5%)</label>
                            <input type="text" class="form-input" id="editProjectCaution" readonly placeholder="Calculé automatiquement" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Nombre des propositions des prix</label>
                            <input type="number" class="form-input" id="editProjectNombrePropositions" min="0" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Date de démarrage *</label>
                            <input type="date" class="form-input" id="editProjectStartDate" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Date de fin prévue *</label>
                            <input type="date" class="form-input" id="editProjectEndDate" required />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Délai</label>
                            <input type="text" class="form-input" id="editProjectDelai" readonly placeholder="Calculé automatiquement" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Maître d'œuvre</label>
                            <input type="text" class="form-input" id="editProjectMaitreOeuvre" placeholder="Ex: Bureau d'études ABC" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Wilaya</label>
                            <select class="form-select" id="editProjectWilaya">
                                <option value="">Sélectionner une wilaya...</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Daïra</label>
                            <select class="form-select" id="editProjectDaira" disabled>
                                <option value="">Sélectionner une daïra...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Commune</label>
                        <select class="form-select" id="editProjectCommune" disabled>
                            <option value="">Sélectionner une commune...</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelEditProjectBtn">Annuler</button>
                <button class="btn btn-primary" id="saveEditProjectBtn">
                    <i class="fa-solid fa-check"></i> Enregistrer
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Confirmation Suppression -->
    <div class="modal-overlay" id="deleteConfirmModal">
        <div class="modal modal-sm">
            <div class="modal-header modal-header--danger">
                <h2 class="modal-title">
                    <i class="fa-solid fa-triangle-exclamation"></i> Confirmer la suppression
                </h2>
                <button class="modal-close" id="closeDeleteConfirmModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="delete-confirm-content">
                    <div class="delete-confirm-icon">
                        <i class="fa-solid fa-trash"></i>
                    </div>
                    <p>Êtes-vous sûr de vouloir supprimer le projet :</p>
                    <p class="delete-confirm-name" id="deleteProjectName"></p>
                    <p class="delete-confirm-warning">
                        <i class="fa-solid fa-exclamation-circle"></i>
                        Cette action est irréversible. Toutes les données associées seront perdues.
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelDeleteBtn">Annuler</button>
                <button class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash"></i> Supprimer définitivement
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Upload Document -->
    <div class="modal-overlay" id="uploadDocModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-cloud-arrow-up"></i> Ajouter un document
                </h2>
                <button class="modal-close" id="closeUploadDocModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="uploadDocForm" enctype="multipart/form-data">
                    <div class="form-group">
                        <label class="form-label">Fichier *</label>
                        <div class="file-drop-zone" id="fileDropZone">
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                            <p>Glissez un fichier ici ou <strong>cliquez pour parcourir</strong></p>
                            <small>PDF, Word, Excel, Images, DWG — max 50 Mo</small>
                            <input type="file" id="docFileInput" style="display:none"
                                   accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.png,.jpg,.jpeg,.dwg,.dxf,.zip,.rar,.txt,.csv" />
                        </div>
                        <div class="file-selected-name" id="fileSelectedName" style="display:none">
                            <i class="fa-solid fa-file"></i>
                            <span id="fileSelectedText"></span>
                            <button type="button" class="btn btn-sm btn-outline" id="fileClearBtn">&times;</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelUploadDocBtn">Annuler</button>
                <button class="btn btn-primary" id="saveUploadDocBtn" disabled>
                    <i class="fa-solid fa-upload"></i> Envoyer
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Confirmation suppression document -->
    <div class="modal-overlay" id="deleteDocConfirmModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-triangle-exclamation" style="color:var(--color-red)"></i> Supprimer le document
                </h2>
                <button class="modal-close" id="closeDeleteDocModal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer le document <strong id="deleteDocName"></strong> ?</p>
                <p style="color:var(--text-tertiary);font-size:var(--font-sm)">Cette action est irréversible.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelDeleteDocBtn">Annuler</button>
                <button class="btn btn-danger" id="confirmDeleteDocBtn">
                    <i class="fa-solid fa-trash"></i> Supprimer
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Rapport Formulaire -->
    <div class="modal-overlay" id="rapportFormModal">
        <div class="modal modal-lg">
            <div class="modal-header">
                <h2 class="modal-title" id="rapportFormTitle">
                    <i class="fa-solid fa-file-lines"></i> Nouveau Rapport
                </h2>
                <button class="modal-close" id="closeRapportFormModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="rapportForm">
                    <input type="hidden" id="rapportType" />

                    <div class="form-row">
                        <div class="form-group" style="flex:2">
                            <label class="form-label">Titre du rapport *</label>
                            <input type="text" class="form-input" id="rapportTitre" required placeholder="Ex: Contrôle qualité – Lot 3" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Projet associé</label>
                            <select class="form-select" id="rapportProjet">
                                <option value="">Aucun projet</option>
                            </select>
                        </div>
                    </div>

                    <!-- Champs dynamiques selon le type -->
                    <div id="rapportDynamicFields"></div>

                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelRapportFormBtn">Annuler</button>
                <button class="btn btn-primary" id="saveRapportBtn">
                    <i class="fa-solid fa-check"></i> Générer le rapport
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Visualisation / Impression Rapport -->
    <div class="modal-overlay" id="rapportViewModal">
        <div class="modal modal-lg">
            <div class="modal-header">
                <h2 class="modal-title" id="rapportViewTitle">
                    <i class="fa-solid fa-eye"></i> Rapport
                </h2>
                <button class="modal-close" id="closeRapportViewModal">&times;</button>
            </div>
            <div class="modal-body" id="rapportViewBody" style="padding:0;">
                <div id="rapportPrintArea" class="rapport-print-area">
                    <!-- Contenu du rapport pour impression -->
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="closeRapportViewBtn">Fermer</button>
                <button class="btn btn-primary" id="downloadPdfBtn" style="display:none;">
                    <i class="fa-solid fa-file-pdf"></i> Télécharger PDF
                </button>
                <button class="btn btn-primary" id="printRapportBtn">
                    <i class="fa-solid fa-print"></i> Imprimer
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Confirmation Suppression Rapport -->
    <div class="modal-overlay" id="deleteRapportConfirmModal">
        <div class="modal modal-sm">
            <div class="modal-header modal-header--danger">
                <h2 class="modal-title">
                    <i class="fa-solid fa-triangle-exclamation"></i> Confirmer la suppression
                </h2>
                <button class="modal-close" id="closeDeleteRapportModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="delete-confirm-content">
                    <div class="delete-confirm-icon">
                        <i class="fa-solid fa-trash"></i>
                    </div>
                    <p>Êtes-vous sûr de vouloir supprimer le rapport :</p>
                    <p class="delete-confirm-name" id="deleteRapportName"></p>
                    <p class="delete-confirm-warning">
                        <i class="fa-solid fa-exclamation-circle"></i>
                        Cette action est irréversible. Le rapport sera définitivement supprimé.
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelDeleteRapportBtn">Annuler</button>
                <button class="btn btn-danger" id="confirmDeleteRapportBtn">
                    <i class="fa-solid fa-trash"></i> Supprimer définitivement
                </button>
            </div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- MODALES MONTANT – Ajout Lot / Tâche / Situation / Avenant / Facture -->
    <!-- ========================================== -->

    <!-- Modal Ajouter un Lot (Devis) -->
    <div class="modal-overlay" id="montantDevisModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-file-invoice"></i> Ajouter un Lot
                </h2>
                <button class="modal-close" id="closeMontantDevisModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="montantDevisForm">
                    <div class="form-group">
                        <label class="form-label">Désignation du lot *</label>
                        <input type="text" class="form-input" id="mDevisDesignation" required
                               placeholder="Ex: Gros œuvre, Maçonnerie..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Montant HT (DA) *</label>
                        <input type="number" class="form-input" id="mDevisMontantHT" required
                               min="0" step="0.01" placeholder="Ex: 5000000" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelMontantDevisBtn">Annuler</button>
                <button class="btn btn-primary" id="saveMontantDevisBtn">
                    <i class="fa-solid fa-check"></i> Ajouter le lot
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Ajouter une Tâche Projet -->
    <div class="modal-overlay" id="montantTacheModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-pen"></i> Modifier les montants
                </h2>
                <button class="modal-close" id="closeMontantTacheModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="montantTacheForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Montant prévu (DA) *</label>
                            <input type="number" class="form-input" id="mTacheMontantPrevu" required
                                   min="0" step="0.01" placeholder="Ex: 2000000" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Montant réalisé (DA)</label>
                            <input type="number" class="form-input" id="mTacheMontantRealise"
                                   min="0" step="0.01" value="0" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelMontantTacheBtn">Annuler</button>
                <button class="btn btn-primary" id="saveMontantTacheBtn">
                    <i class="fa-solid fa-check"></i> Enregistrer
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Ajouter une Situation de Paiement -->
    <div class="modal-overlay" id="montantSituationModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-calendar-check"></i> Nouvelle Situation
                </h2>
                <button class="modal-close" id="closeMontantSituationModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="montantSituationForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">N° de situation *</label>
                            <input type="number" class="form-input" id="mSituationNumero" required
                                   min="1" placeholder="Ex: 1" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Date *</label>
                            <input type="date" class="form-input" id="mSituationDate" required />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Montant validé (DA) *</label>
                            <input type="number" class="form-input" id="mSituationMontant" required
                                   min="0" step="0.01" placeholder="Ex: 2000000" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">% Cumulé *</label>
                            <input type="number" class="form-input" id="mSituationPourcentage" required
                                   min="0" max="100" step="0.1" placeholder="Ex: 25.5" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelMontantSituationBtn">Annuler</button>
                <button class="btn btn-primary" id="saveMontantSituationBtn">
                    <i class="fa-solid fa-check"></i> Ajouter la situation
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Ajouter un Avenant -->
    <div class="modal-overlay" id="montantAvenantModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-file-pen"></i> Nouvel Avenant
                </h2>
                <button class="modal-close" id="closeMontantAvenantModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="montantAvenantForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">N° d'avenant *</label>
                            <input type="number" class="form-input" id="mAvenantNumero" required
                                   min="1" placeholder="Ex: 1" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Date</label>
                            <input type="date" class="form-input" id="mAvenantDate" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Motif *</label>
                        <textarea class="form-textarea" id="mAvenantMotif" rows="2" required
                                  placeholder="Ex: Ajout d'un parking souterrain"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Montant (DA) * <small style="color:var(--text-tertiary)">(positif = ajout, négatif = retrait)</small></label>
                        <input type="number" class="form-input" id="mAvenantMontant" required
                               step="0.01" placeholder="Ex: 1500000 ou -200000" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelMontantAvenantBtn">Annuler</button>
                <button class="btn btn-primary" id="saveMontantAvenantBtn">
                    <i class="fa-solid fa-check"></i> Ajouter l'avenant
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Ajouter une Facture -->
    <div class="modal-overlay" id="montantFactureModal">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-receipt"></i> Nouvelle Facture
                </h2>
                <button class="modal-close" id="closeMontantFactureModal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="montantFactureForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">N° de facture *</label>
                            <input type="text" class="form-input" id="mFactureNumero" required
                                   placeholder="Ex: FAC-2025-001" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Date *</label>
                            <input type="date" class="form-input" id="mFactureDate" required />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Montant (DA) *</label>
                            <input type="number" class="form-input" id="mFactureMontant" required
                                   min="0" step="0.01" placeholder="Ex: 2000000" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Statut</label>
                            <select class="form-select" id="mFactureStatut">
                                <option value="Elaboree">Élaborée</option>
                                <option value="Validee">Validée</option>
                                <option value="Signee">Signée</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Situation liée</label>
                        <select class="form-select" id="mFactureSituation">
                            <option value="">Aucune</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelMontantFactureBtn">Annuler</button>
                <button class="btn btn-primary" id="saveMontantFactureBtn">
                    <i class="fa-solid fa-check"></i> Ajouter la facture
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Mon Profil -->
    <div class="modal-overlay" id="myProfileModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-id-card"></i> Mon Profil
                </h2>
                <button class="modal-close" id="closeMyProfileModal">&times;</button>
            </div>
            <div class="modal-body" id="myProfileBody">
                <div class="my-profile-loading" style="text-align:center;padding:40px;">
                    <i class="fa-solid fa-spinner fa-spin" style="font-size:24px;color:var(--text-tertiary);"></i>
                    <p style="color:var(--text-tertiary);margin-top:8px;">Chargement...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notifications -->
    <div class="toast-container" id="toastContainer"></div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
