@page
@model IngeProjets.Pages.RegisterModel
@{
    Layout = null;
}

<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cr&#233;er un compte - Ing&#233;-Projets</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="stylesheet" href="~/css/Register.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

<div class="container">

    <div class="left">
        <img src="~/images/logo.png" class="logo" />

        <h2 class="brand">
            <span class="ing">Ing&#233;</span><span class="dash">-</span>
            <span class="pro">Pro</span><span class="jets">jets</span>
        </h2>

        <p class="tagline">
            Le suivi technique, ma&#238;tris&#233;<br />
            &#224; la perfection
        </p>
    </div>

    <div class="right">
        <h1>Cr&#233;er un compte</h1>
        <p class="subtitle">
            Remplissez vos informations pour acc&#233;der &#224; Ing&#233;-Projets.
        </p>

        <form method="post">

            <div class="row">
                <div class="input-box">
                    <i class="fa-solid fa-user"></i>
                    <input asp-for="Nom" placeholder="Nom" required />
                </div>

                <div class="input-box">
                    <i class="fa-solid fa-user"></i>
                    <input asp-for="Prenom" placeholder="Pr&#233;nom" required />
                </div>
            </div>

            <div class="input-box full">
                <i class="fa-solid fa-envelope"></i>
                <input asp-for="Email" type="email"
                       placeholder="email@exemple.com" required />
            </div>

           
            <div class="input-box full">
                <i class="fa-solid fa-lock"></i>
                <input asp-for="Password" type="password"
                       placeholder="Mot de passe (min. 8 car., 1 majuscule, 1 chiffre, 1 sp&#233;cial)" required />
            </div>

            <div class="input-box full">
                <i class="fa-solid fa-lock"></i>
                <input asp-for="ConfirmPassword" type="password"
                       placeholder="Confirmer le mot de passe" required />
            </div>

            <button class="btn">Cr&#233;er un compte</button>

            <p class="login"
               onclick="window.location.href='/Login'"
               style="cursor:pointer;">
                D&#233;j&#224; un compte ? <strong>Se connecter &#8594;</strong>
            </p>

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                var color = Model.IsSuccess ? "green" : "red";
                <p style="text-align:center;color:@color;font-weight:600;">
                    @Model.Message
                </p>
            }

            <div asp-validation-summary="All" style="color:red;font-size:0.9em;text-align:center;"></div>

        </form>
    </div>

</div>

</body>
</html>
